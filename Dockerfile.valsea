# Valsea WebSocket proxy only (no `next build`). Use as a second Railway service:
# Dashboard → service → Build → Dockerfile path: Dockerfile.valsea
FROM node:20-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY scripts/valsea-ws-proxy.mjs ./scripts/valsea-ws-proxy.mjs

ENV NODE_ENV=production

CMD ["node", "scripts/valsea-ws-proxy.mjs"]
